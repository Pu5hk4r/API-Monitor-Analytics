# Application Settings
DEBUG=False
APP_NAME=API Monitor System

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GEMINI_API_KEY=your-gemini-api-key

# Database Configuration
SQLITE_DB_PATH=/app/database/metrics.db
DATA_RETENTION_DAYS=7

# Cache Settings
CACHE_TTL_SECONDS=300

# Scheduler Settings
MONITOR_CHECK_INTERVAL_MINUTES=5
MAX_WORKERS=10
REQUEST_TIMEOUT_SECONDS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS - Add your frontend URLs
ALLOWED_ORIGINS=["http://localhost:3000","https://monitor.yourdomain.com"]

# Logging
LOG_LEVEL=INFO
CLOUDWATCH_LOG_GROUP=/aws/ec2/api-monitor

# Alert Settings
MAX_CONSECUTIVE_FAILURES=3
ALERT_COOLDOWN_MINUTES=30
